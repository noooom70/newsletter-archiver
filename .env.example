# Override the default client ID if you have your own Azure AD app
# AZURE_CLIENT_ID=your-azure-app-client-id

# Archive files location (default: ~/.newsletter-archive)
# Can be pointed at a cloud-synced drive for backup.
# ARCHIVE_DIR=~/newsletter-archive

# Email account being archived (informational, shown in `config show`)
# OUTLOOK_EMAIL=you@example.com

# Required for RAG Q&A (`search ask`)
# ANTHROPIC_API_KEY=sk-ant-...
